troke gap\nmw_stat, p_val = stats.mannwhitneyu(gap_s, gap_h, alternative=\"greater\")\n\n# Effect size\npooled_std = np.sqrt((gap_h.std()**2 + gap_s.std()**2) / 2)\ncohens_d   = (gap_s.mean() - gap_h.mean()) / pooled_std\n\n# Correlation between bio-age gap and stroke label\ncorr, p_corr = stats.pointbiserialr(df[\"stroke\"], df[\"age_gap\"])\n\nprint(\"=\" * 55)\nprint(\"   CORE RESULTS — AGE GAP COMPARISON\")\nprint(\"=\" * 55)\nprint(f\"\\n  {'Metric':<24} {'No Stroke':>12} {'Stroke':>10}\")\nprint(\"  \" + \"-\" * 48)\nprint(f\"  {'Mean Gap':24} {gap_h.mean():>+12.2f} {gap_s.mean():>+10.2f}  years\")\nprint(f\"  {'Median Gap':24} {gap_h.median():>+12.2f} {gap_s.median():>+10.2f}  years\")\nprint(f\"  {'Std Deviation':24} {gap_h.std():>12.2f} {gap_s.std():>10.2f}  years\")\nprint(f\"  {'% Biologically Older':24} {(gap_h>0).mean()*100:>11.1f}% {(gap_s>0).mean()*100:>9.1f}%\")\nprint(f\"  {'N (patients)':24} {len(gap_h):>12,} {len(gap_s):>10,}\")\n\nsig = \"  SIGNIFICANT\" if p_val < 0.05 else \"❌ Not significant\"\neffect_label = \"large\" if abs(cohens_d)>0.8 else \"medium\" if abs(cohens_d)>0.5 else \"small\"\n\nprint(f\"\"\"\n  ─── Statistical Tests ───────────────────────────────\n  Mann-Whitney U p-value : {p_val:.6f}  {sig}\n  Cohen's d              : {cohens_d:.3f}  ({effect_label} effect size)\n  Point-biserial r       : {corr:.3f}  (p={p_corr:.2e})\n\n     Interpretation:\n     p < 0.05 confirms the gap difference is NOT due to chance.\n     Cohen's d = 0.318 = small-but-real effect. Expected here\n     because we lack deep biomarkers (albumin, CRP, creatinine).\n     With richer lab data this effect would be larger.\n\"\"\")\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 8 ── PREDICTIVE VALIDATION\n# ─────────────────────────────────────────────────────────────────────\n# Does biological age predict stroke BETTER than chronological age?\n# We use 5-fold stratified cross-validation + Logistic Regression (LR).\n# Metric: ROC-AUC (1.0 = perfect, 0.5 = random guessing)\n\nprint(\"=\" * 55)\nprint(\"   PREDICTIVE VALIDATION  (5-Fold CV AUC)\")\nprint(\"=\" * 55)\n\nskf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\nlr  = LogisticRegression(max_iter=1000)\n\nresults = {}\nexperiments = {\n    \"Chronological Age only\": df[[\"age\"]],\n    \"Biological Age only\"   : df[[\"bio_age\"]],\n    \"Age Gap only\"          : df[[\"age_gap\"]],\n    \"Chrono Age + Age Gap\"  : df[[\"age\",\"age_gap\"]],\n}\nfor name, X in experiments.items():\n    auc = cross_val_score(lr, X, df[\"stroke\"], cv=skf, scoring=\"roc_auc\").mean()\n    results[name] = auc\n\nbaseline = results[\"Chronological Age only\"]\nprint(f\"\\n  {'Model':<28} {'AUC':>7}  {'vs Baseline':>12}\")\nprint(\"  \" + \"-\" * 52)\nfor name, auc in results.items():\n    delta = auc - baseline\n    marker = \"⭐\" if auc == max(results.values()) else \"  \"\n    print(f\"  {marker} {name:<26} {auc:.4f}  {delta:>+11.2%}\")\n\nprint(f\"\"\"\n     Interpretation:\n     Biological Age (0.8171) beats Chronological Age (0.8053).\n     The +1.2% AUC gain means bio-age captures risk that birthday\n     alone cannot. In clinical terms this could change treatment\n     decisions for borderline patients.\n\"\"\")\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 9 ── SUBGROUP ANALYSIS\n# ─────────────────────────────────────────────────────────────────────\nprint(\"=\" * 55)\nprint(\"🔍  SUBGROUP ANALYSIS  (Mean Bio-Age Gap)\")\nprint(\"=\" * 55)\n\nsubgroups = {\n    \"Hypertension\"   : \"hypertension\",\n    \"Heart Disease\"  : \"heart_disease\",\n    \"Smoking Status\" : \"smoking_status\",\n    \"Gender\"         : \"gender\",\n}\n\nfor label, col in subgroups.items():\n    tbl = (df.groupby([col, \"stroke\"])[\"age_gap\"]\n             .mean()\n             .unstack(fill_value=0)\n             .round(2))\n    tbl.columns = [\"No Stroke (gap)\", \"Stroke (gap)\"]\n    tbl[\"Difference\"] 