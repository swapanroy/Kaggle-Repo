 THIS NOTEBOOK DOES:\n#   Your birth certificate says you're 40. But what does your BODY say?\n#   This notrbook computes each patient's \"Biological Age\" using 5 clinical\n#   biomarkers and asks: do stroke patients age faster biologically?\n#\n#   KEY QUESTION:\n#   → Do stroke patients show accelerated biological aging\n#     compared to people who never had a stroke?\n#\n#   METHOD (KDM-Inspired Deviation):\n#   1. For each biomarker, model what a HEALTHY person's value looks\n#      like at each age (the \"healthy reference line\")\n#   2. Measure how far each patient DEVIATES from that healthy norm\n#   3. Convert those deviations into a single \"Bio-Age Gap\" (in years)\n#   4. Compare gap between stroke vs non-stroke groups\n#\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 1 ── IMPORTS & SETUP\n# ─────────────────────────────────────────────────────────────────────\nimport pandas as pd\nimport numpy as np\nimport torch\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom scipy import stats\nfrom sklearn.linear_model import LinearRegression, LogisticRegression\nfrom sklearn.model_selection import cross_val_score, StratifiedKFold\nfrom transformers import AutoTokenizer, AutoModelForCausalLM, pipeline\nfrom scipy import stats\nfrom sklearn.linear_model import LinearRegression\nfrom kaggle_secrets import UserSecretsClient\nfrom huggingface_hub import login\nimport torch\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n# Notebook display settings\npd.set_option(\"display.float_format\", \"{:.2f}\".format)\npd.set_option(\"display.max_columns\", 20)\n\nprint(\" Libraries loaded successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-03T19:54:37.874733Z","iopub.execute_input":"2026-03-03T19:54:37.874990Z","iopub.status.idle":"2026-03-03T19:54:57.478862Z","shell.execute_reply.started":"2026-03-03T