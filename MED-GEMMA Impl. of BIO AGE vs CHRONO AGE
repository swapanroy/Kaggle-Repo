df[\"bmi\"] = pd.to_numeric(df[\"bmi\"], errors=\"coerce\")\ndf = df.dropna(subset=[\"bmi\"])\nprint(f\"  After dropping missing BMI → {len(df):,} patients\")\n\n# ── Encode smoking status as an ordered risk score ──────────────────\n#   never smoked = 0   (lowest risk)\n#   Unknown      = 0.5 (uncertain)\n#   formerly     = 1   (past exposure)\n#   smokes       = 2   (active, highest risk)\nsmoking_map = {\n    \"never smoked\":   0,\n    \"Unknown\":        0.5,\n    \"formerly smoked\":1,\n    \"smokes\":         2\n}\ndf[\"smoking_encoded\"] = df[\"smoking_status\"].map(smoking_map).fillna(0.5)\n\n# ── Split into healthy reference group and stroke group ─────────────\nhealthy = df[df[\"stroke\"] == 0].copy()   # used to build reference model\nstroke  = df[df[\"stroke\"] == 1].copy()   # group we test the hypothesis on\n\nprint(f\"\\n  Healthy (no-stroke) patients : {len(healthy):,}\")\nprint(f\"  Stroke patients              : {len(stroke):,}\")\nprint(\"\\n Cleaning complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-03T19:55:39.971320Z","iopub.execute_input":"2026-03-03T19:55:39.971923Z","iopub.status.idle":"2026-03-03T19:55:40.047151Z","shell.execute_reply.started":"2026-03-03T19:55:39.971897Z","shell.execute_reply":"2026-03-03T19:55:40.046372Z"}},"outputs":[{"name":"stdout","text":"=======================================================\n  DATASET OVERVIEW\n=======================================================\n  Total patients  : 4,981\n  Total features  : 11\n  Stroke cases    : 248  (5.0%)\n  No-stroke cases : 4,733  (95.0%)\n\n  Missing values  :\n  → None! Clean dataset.\n\n  Sample rows:\n\n=======================================================\n  DATA CLEANING\n=======================================================\n  Removed 823 patients under 18 → 4,158 adults remain\n  After dropping missing BMI → 4,158 patients\n\n  Healthy (no-stroke) patients : 3,912\n  Stroke patients              : 246\n\n Cleaning complete\n","output_type":"stream"}],"execution_count":5},{"cell_type":"markdown","source":"## BioMarker Configurations","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 4 ── BIOMARKER CONFIGURATION\n# ─────────────────────────────────────────────────────────────────────\n# 🔬 These are the 5 biomarkers used to estimate biological age.\n#\n# Each biomarker has two settings:\n#   direction : +1 means HIGHER value = biologically OLDER\n#   weight    : clinical importance (must sum to exactly 1.0)\n#\n# Weight rationale (evidence-based):\n#   avg_glucose_level → 0.30  strongest continuous aging signal\n#   bmi               → 0.25  metabolic burden\n#   hypertension      → 0.25  well-established accelerated aging\n#   heart_disease     → 0.15  strong but narrower prevalence\n#   smoking_encoded   → 0.05  partially captured in other markers\n\nBIOMARKERS = {\n    \"avg_glucose_level\": {\"direction\": +1, \"weight\": 0.30},\n    \"bmi\":               {\"direction\": +1, \"weight\": 0.25},\n    \"hypertension\":      {\"direction\": +1, \"weight\": 0.25},\n    \"heart_disease\":     {\"direction\": +1, \"weight\": 0.15},\n    \"smoking_encoded\":   {\"direction\": +1, \"weight\": 0.05},\n}\n\n# Validate weights sum to 1\ntotal_weight = sum(cfg[\"weight\"] for cfg in BIOMARKERS.values())\nassert abs(total_weight - 1.0) < 0.001, f\"Weights must sum to 1.0, got {total_weight}\"\nprint(f\" Biomarker weights sum to {total_weight:.2f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-03T19:55:40.048429Z","iopub.execute_input":"2026-03-03T19:55:40.049065Z","iopub.status.idle":"2026-03-03T19:55:44.580813Z","shell.execute_reply.started":"2026-03-03T19:55:40.049027Z","shell.execute_reply":"2026-03-03T19:55:44.578192Z"}},"outputs":[{"name":"stdout","text":" Biomarker weights sum to 1.00\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"## Healthy Reference Line","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 5 ── BUILD HEALTHY REFERENCE LINES\n# ─────────────────────────────────────────────────────────────────────\n#   CONCEPT:\n#   For each biomarker, we fit a line: biomarker = f(age)\n#   using ONLY the healthy population (stroke =0)\n#   This tells us: \"What COULD be this biomarker look like at age X?\"\n#\n#   Example: A healthy 60-year-old has avg glucose ≈ 118.\n#   If a stroke patient aged 60 has glucose = 180,\n#   their deviation = 180 - 118 = +62 → biologically older.\n\nreference_models      = {}   # stores the fitted linear model per biomarker\nhealthy_residual_stds = {}   # stores the spread (std) of healthy deviations\n\nprint(\"=\" * 55)\nprint(\"   HEALTHY REFERENCE LINES  (biomarker ~ age)\")\nprint(\"=\" * 55)\nprint(f\"  {'Biomarker':<22} {'Slope':>10} {'r':>7} {'Std Dev':>10}\")\nprint(\"  \" + \"-\" * 50)\n\nfor bm, cfg in BIOMARKERS.items():\n    X      = healthy[[\"age\"]].values\n    y      = healthy[bm].values\n    model  = LinearRegression().fit(X, y)\n    resids = y - model.predict(X)\n    std    = max(resids.std(), 1e-6)   # avoid division by zero\n    r      = np.corrcoef(healthy[\"age\"], healthy[bm])[0, 1]\n\n    reference_models[bm]      = model\n    healthy_residual_stds[bm] = std\n\n    print(f\"  {bm:<22} {model.coef_[0]:>+10.4f} {r:>+7.3f} {std:>10.3f}\")\n\nprint(\"\"\"\n     How to read this table:\n     Slope   = how much the biomarker changes per year in healthy people\n     r       = correlation with age (closer to ±1 = stronger age signal)\n     Std Dev = how much healthy people of the same age vary\n               (used to normalise deviations into z-scores)\n\"\"\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-03T19:55:44.585702Z","iopub.execute_input":"2026-03-03T19:55:44.586183Z","iopub.status.idle":"2026-03-03T19:55:55.406138Z","shell.execute_reply.started":"2026-03-03T19:55:44.586147Z","shell.execute_reply":"2026-03-03T19:55:55.403192Z"}},"outputs":[{"name":"stdout","text":"=======================================================\n   HEALTHY REFERENCE LINES  (biomarker ~ age)\n=======================================================\n  Biomarker                   Slope       r    Std Dev\n  --------------------------------------------------\n  avg_glucose_level         +0.5527  +0.211     45.011\n  bmi                       +0.0243  +0.070      6.114\n  hypertension              +0.0042  +0.241      0.298\n  heart_disease             +0.0035  +0.262      0.226\n  smoking_encoded           +0.0002  +0.004      0.736\n\n     How to read this table:\n     Slope   = how much the biomarker changes per year in healthy people\n     r       = correlation with age (closer to ±1 = stronger age signal)\n     Std Dev = how much healthy people of the same age vary\n               (used to normalise deviations into z-scores)\n\n","output_type":"stream"}],"execution_count":7},{"cell_type":"markdown","source":"## Computing AGE gap","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 6 ── COMPUTE BIOLOGICAL AGE GAP\n# ─────────────────────────────────────────────────────────────────────\n#   FORMULA (per patient):\n#\n#   For each biomarker:\n#     expected = reference_model.predict(patient_age)\n#     z_score  = (actual - expected) / healthy_std\n#     directed = z_score × direction   (+1 ensures higher = older)\n#\n#   Weighted z = sum(directed × weight)\n#   Bio-Age Gap (years) = Weighted z × scale_factor\n#\n# scale_factor = 5.0  → converts z-score units into interpretable years.\n# We then calibrate so the healthy group's mean gap = 0 (reference anchor).\n\nSCALE_FACTOR = 5.0\n\ndef compute_bio_age_gap(row):\n    \"\"\"\n    Computes how many years biologically OLDER (or younger)\n    a patient appears vs a healthy person of the same age.\n    Positive = body is older than birth certificate.\n    Negative = body is younger than birth certificate.\n    \"\"\"\n    weighted_z = 0.0\n    for bm, cfg in BIOMARKERS.items():\n        expected   = reference_models[bm].predict([[row[\"age\"]]])[0]\n        z          = (row[bm] - expected) / healthy_residual_stds[bm]\n        weighted_z += (z * cfg[\"direction\"]) * cfg[\"weight\"]\n    return weighted_z * SCALE_FACTOR\n\n# Apply to all patients\ndf[\"age_gap_raw\"]  = df.apply(compute_bio_age_gap, axis=1)\n\n# Calibrate: anchor healthy mean to 0 so gap is purely relative\ncalibration_offset = df.loc[df[\"stroke\"] == 0, \"age_gap_raw\"].mean()\ndf[\"age_gap\"]      = df[\"age_gap_raw\"] - calibration_offset\ndf[\"bio_age\"]      = df[\"age\"] + df[\"age_gap\"]\ndf[\"accelerated\"]  = (df[\"age_gap\"] > 0).astype(int)  # 1 if biologically older\n\n# Refresh group splits with computed columns\nhealthy = df[df[\"stroke\"] == 0].copy()\nstroke  = df[df[\"stroke\"] == 1].copy()\n\n# Add age groups for subgroup analysis\ndf[\"age_group\"] = pd.cut(df[\"age\"], bins=[17,40,55,65,120],\n                          labels=[\"18–40\", \"40–55\", \"55–65\", \"65+\"])\nhealthy = df[df[\"stroke\"] == 0].copy()\nstroke  = df[df[\"stroke\"] == 1].copy()\n\nprint(\"✅ Biological age computed for all patients\")\nprint(f\"\\n  Sample output (5 rows):\")\ndf[[\"age\",\"bio_age\",\"age_gap\",\"accelerated\",\"stroke\"]].head()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-03T19:55:55.410345Z","iopub.execute_input":"2026-03-03T19:55:55.411223Z","iopub.status.idle":"2026-03-03T19:56:02.506264Z","shell.execute_reply.started":"2026-03-03T19:55:55.411139Z","shell.execute_reply":"2026-03-03T19:56:02.505531Z"}},"outputs":[{"name":"stdout","text":"✅ Biological age computed for all patients\n\n  Sample output (5 rows):\n","output_type":"stream"},{"execution_count":8,"output_type":"execute_result","data":{"text/plain":"    age  bio_age  age_gap  accelerated  stroke\n0 67.00    74.30     7.30 