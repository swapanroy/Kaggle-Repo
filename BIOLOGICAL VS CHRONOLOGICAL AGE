{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":4029610,"datasetId":2387714,"databundleVersionId":4085554}],"dockerImageVersionId":31286,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"## 🧬 BIOLOGICAL AGE vs CHRONOLOGICAL AGE ","metadata":{}},{"cell_type":"code","source":"# ╔══════════════════════════════════════════════════════════════════╗\n# ║       🧬 BIOLOGICAL AGE vs CHRONOLOGICAL AGE                    ║\n# ║                Stroke Risk Study                                 ║\n# ║                                                                  ║\n# ║  METHOD: KDM-Inspired Biomarker Deviation                        ║\n# ║  DATASET: Brain Stroke Dataset (4,981 patients)                  ║\n# ║  AUTHOR:  Swapan Roy                                             ║\n# ╚══════════════════════════════════════════════════════════════════╝\n#\n#  WHAT THIS NOTEBOOK DOES:\n#   Your birth certificate says you're 40. But what does your BODY say?\n#   This notrbook computes each patient's \"Biological Age\" using 5 clinical\n#   biomarkers and asks: do stroke patients age faster biologically?\n#\n#   KEY QUESTION:\n#   → Do stroke patients show accelerated biological aging\n#     compared to people who never had a stroke?\n#\n#   METHOD (KDM-Inspired Deviation):\n#   1. For each biomarker, model what a HEALTHY person's value looks\n#      like at each age (the \"healthy reference line\")\n#   2. Measure how far each patient DEVIATES from that healthy norm\n#   3. Convert those deviations into a single \"Bio-Age Gap\" (in years)\n#   4. Compare gap between stroke vs non-stroke groups\n#\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 1 ── IMPORTS & SETUP\n# ─────────────────────────────────────────────────────────────────────\nimport pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom scipy import stats\nfrom sklearn.linear_model import LinearRegression, LogisticRegression\nfrom sklearn.model_selection import cross_val_score, StratifiedKFold\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n# Notebook display settings\npd.set_option(\"display.float_format\", \"{:.2f}\".format)\npd.set_option(\"display.max_columns\", 20)\n\nprint(\" Libraries loaded successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-01T23:07:55.598083Z","iopub.execute_input":"2026-03-01T23:07:55.598396Z","iopub.status.idle":"2026-03-01T23:07:56.834765Z","shell.execute_reply.started":"2026-03-01T23:07:55.598369Z","shell.execute_reply":"2026-03-01T23:07:56.833960Z"}},"outputs":[{"name":"stdout","text":" Libraries loaded successfully\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"## Data Loading and Cleaning","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 2 ── LOAD & EXPLORE DATA\n# ─────────────────────────────────────────────────────────────────────\n#  Update this path if your CSV is stored elsewhere\nDATA_PATH = \"/kaggle/input/datasets/jillanisofttech/brain-stroke-dataset/brain_stroke.csv\"\n\ndf_raw = pd.read_csv(DATA_PATH)\n\nprint(\"=\" * 55)\nprint(\"  DATASET OVERVIEW\")\nprint(\"=\" * 55)\nprint(f\"  Total patients  : {len(df_raw):,}\")\nprint(f\"  Total features  : {df_raw.shape[1]}\")\nprint(f\"  Stroke cases    : {df_raw['stroke'].sum():,}  ({df_raw['stroke'].mean()*100:.1f}%)\")\nprint(f\"  No-stroke cases : {(df_raw['stroke']==0).sum():,}  ({(df_raw['stroke']==0).mean()*100:.1f}%)\")\nprint(f\"\\n  Missing values  :\")\nmissing = df_raw.isnull().sum()\nif missing.any():\n    print(missing[missing > 0])\nelse:\n    print(\"  → None! Clean dataset.\")\n\nprint(f\"\\n  Sample rows:\")\ndf_raw.head(3)\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 3 ── DATA CLEANING\n# ─────────────────────────────────────────────────────────────────────\nprint(\"\\n\" + \"=\" * 55)\nprint(\"  DATA CLEANING\")\nprint(\"=\" * 55)\n\ndf = df_raw.copy()\n\n# Keep only adults (children have different biomarker profiles)\nbefore = len(df)\ndf = df[df[\"age\"] >= 18].reset_index(drop=True)\nprint(f\"  Removed {before - len(df)} patients under 18 → {len(df):,} adults remain\")\n\n# Convert BMI to numeric (handles any stray strings)\ndf[\"bmi\"] = pd.to_numeric(df[\"bmi\"], errors=\"coerce\")\ndf = df.dropna(subset=[\"bmi\"])\nprint(f\"  After dropping missing BMI → {len(df):,} patients\")\n\n# ── Encode smoking status as an ordered risk score ──────────────────\n#   never smoked = 0   (lowest risk)\n#   Unknown      = 0.5 (uncertain)\n#   formerly     = 1   (past exposure)\n#   smokes       = 2   (active, highest risk)\nsmoking_map = {\n    \"never smoked\":   0,\n    \"Unknown\":        0.5,\n    \"formerly smoked\":1,\n    \"smokes\":         2\n}\ndf[\"smoking_encoded\"] = df[\"smoking_status\"].map(smoking_map).fillna(0.5)\n\n# ── Split into healthy reference group and stroke group ─────────────\nhealthy = df[df[\"stroke\"] == 0].copy()   # used to build reference model\nstroke  = df[df[\"stroke\"] == 1].copy()   # group we test the hypothesis on\n\nprint(f\"\\n  Healthy (no-stroke) patients : {len(healthy):,}\")\nprint(f\"  Stroke patients              : {len(stroke):,}\")\nprint(\"\\n Cleaning complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-01T23:07:56.836035Z","iopub.execute_input":"2026-03-01T23:07:56.836368Z","iopub.status.idle":"2026-03-01T23:07:56.906376Z","shell.execute_reply.started":"2026-03-01T23:07:56.836346Z","shell.execute_reply":"2026-03-01T23:07:56.905511Z"},"jupyter":{"source_hidden":true}},"outputs":[{"name":"stdout","text":"=======================================================\n  DATASET OVERVIEW\n=======================================================\n  Total patients  : 4,981\n  Total features  : 11\n  Stroke cases    : 248  (5.0%)\n  No-stroke cases : 4,733  (95.0%)\n\n  Missing values  :\n  → None! Clean dataset.\n\n  Sample rows:\n\n=======================================================\n  DATA CLEANING\n=======================================================\n  Removed 823 patients under 18 → 4,158 adults remain\n  After dropping missing BMI → 4,158 patients\n\n  Healthy (no-stroke) patients : 3,912\n  Stroke patients              : 246\n\n Cleaning complete\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"## BioMarker Configurations","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 4 ── BIOMARKER CONFIGURATION\n# ─────────────────────────────────────────────────────────────────────\n# 🔬 These are the 5 biomarkers used to estimate biological age.\n#\n# Each biomarker has two settings:\n#   direction : +1 means HIGHER value = biologically OLDER\n#   weight    : clinical importance (must sum to exactly 1.0)\n#\n# Weight rationale (evidence-based):\n#   avg_glucose_level → 0.30  strongest continuous aging signal\n#   bmi               → 0.25  metabolic burden\n#   hypertension      → 0.25  well-established accelerated aging\n#   heart_disease     → 0.15  strong but narrower prevalence\n#   smoking_encoded   → 0.05  partially captured in other markers\n\nBIOMARKERS = {\n    \"avg_glucose_level\": {\"direction\": +1, \"weight\": 0.30},\n    \"bmi\":               {\"direction\": +1, \"weight\": 0.25},\n    \"hypertension\":      {\"direction\": +1, \"weight\": 0.25},\n    \"heart_disease\":     {\"direction\": +1, \"weight\": 0.15},\n    \"smoking_encoded\":   {\"direction\": +1, \"weight\": 0.05},\n}\n\n# Validate weights sum to 1\ntotal_weight = sum(cfg[\"weight\"] for cfg in BIOMARKERS.values())\nassert abs(total_weight - 1.0) < 0.001, f\"Weights must sum to 1.0, got {total_weight}\"\nprint(f\" Biomarker weights sum to {total_weight:.2f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-01T23:07:56.907536Z","iopub.execute_input":"2026-03-01T23:07:56.907806Z","iopub.status.idle":"2026-03-01T23:07:56.913755Z","shell.execute_reply.started":"2026-03-01T23:07:56.907782Z","shell.execute_reply":"2026-03-01T23:07:56.912981Z"},"jupyter":{"source_hidden":true}},"outputs":[{"name":"stdout","text":" Biomarker weights sum to 1.00\n","output_type":"stream"}],"execution_count":4},{"cell_type":"markdown","source":"## Healthy Reference Line","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 5 ── BUILD HEALTHY REFERENCE LINES\n# ─────────────────────────────────────────────────────────────────────\n#   CONCEPT:\n#   For each biomarker, we fit a line: biomarker = f(age)\n#   using ONLY the healthy population (stroke =0)\n#   This tells us: \"What COULD be this biomarker look like at age X?\"\n#\n#   Example: A healthy 60-year-old has avg glucose ≈ 118.\n#   If a stroke patient aged 60 has glucose = 180,\n#   their deviation = 180 - 118 = +62 → biologically older.\n\nreference_models      = {}   # stores the fitted linear model per biomarker\nhealthy_residual_stds = {}   # stores the spread (std) of healthy deviations\n\nprint(\"=\" * 55)\nprint(\"   HEALTHY REFERENCE LINES  (biomarker ~ age)\")\nprint(\"=\" * 55)\nprint(f\"  {'Biomarker':<22} {'Slope':>10} {'r':>7} {'Std Dev':>10}\")\nprint(\"  \" + \"-\" * 50)\n\nfor bm, cfg in BIOMARKERS.items():\n    X      = healthy[[\"age\"]].values\n    y      = healthy[bm].values\n    model  = LinearRegression().fit(X, y)\n    resids = y - model.predict(X)\n    std    = max(resids.std(), 1e-6)   # avoid division by zero\n    r      = np.corrcoef(healthy[\"age\"], healthy[bm])[0, 1]\n\n    reference_models[bm]      = model\n    healthy_residual_stds[bm] = std\n\n    print(f\"  {bm:<22} {model.coef_[0]:>+10.4f} {r:>+7.3f} {std:>10.3f}\")\n\nprint(\"\"\"\n     How to read this table:\n     Slope   = how much the biomarker changes per year in healthy people\n     r       = correlation with age (closer to ±1 = stronger age signal)\n     Std Dev = how much healthy people of the same age vary\n               (used to normalise deviations into z-scores)\n\"\"\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-01T23:07:56.915793Z","iopub.execute_input":"2026-03-01T23:07:56.916065Z","iopub.status.idle":"2026-03-01T23:07:56.953161Z","shell.execute_reply.started":"2026-03-01T23:07:56.916043Z","shell.execute_reply":"2026-03-01T23:07:56.952332Z"},"jupyter":{"source_hidden":true}},"outputs":[{"name":"stdout","text":"=======================================================\n   HEALTHY REFERENCE LINES  (biomarker ~ age)\n=======================================================\n  Biomarker                   Slope       r    Std Dev\n  --------------------------------------------------\n  avg_glucose_level         +0.5527  +0.211     45.011\n  bmi                       +0.0243  +0.070      6.114\n  hypertension              +0.0042  +0.241      0.298\n  heart_disease             +0.0035  +0.262      0.226\n  smoking_encoded           +0.0002  +0.004      0.736\n\n     How to read this table:\n     Slope   = how much the biomarker changes per year in healthy people\n     r       = correlation with age (closer to ±1 = stronger age signal)\n     Std Dev = how much healthy people of the same age vary\n               (used to normalise deviations into z-scores)\n\n","output_type":"stream"}],"execution_count":5},{"cell_type":"markdown","source":"## Computing AGE gap","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 6 ── COMPUTE BIOLOGICAL AGE GAP\n# ─────────────────────────────────────────────────────────────────────\n#   FORMULA (per patient):\n#\n#   For each biomarker:\n#     expected = reference_model.predict(patient_age)\n#     z_score  = (actual - expected) / healthy_std\n#     directed = z_score × direction   (+1 ensures higher = older)\n#\n#   Weighted z = sum(directed × weight)\n#   Bio-Age Gap (years) = Weighted z × scale_factor\n#\n# scale_factor = 5.0  → converts z-score units into interpretable years.\n# We then calibrate so the healthy group's mean gap = 0 (reference anchor).\n\nSCALE_FACTOR = 5.0\n\ndef compute_bio_age_gap(row):\n    \"\"\"\n    Computes how many years biologically OLDER (or younger)\n    a patient appears vs a healthy person of the same age.\n    Positive = body is older than birth certificate.\n    Negative = body is younger than birth certificate.\n    \"\"\"\n    weighted_z = 0.0\n    for bm, cfg in BIOMARKERS.items():\n        expected   = reference_models[bm].predict([[row[\"age\"]]])[0]\n        z          = (row[bm] - expected) / healthy_residual_stds[bm]\n        weighted_z += (z * cfg[\"direction\"]) * cfg[\"weight\"]\n    return weighted_z * SCALE_FACTOR\n\n# Apply to all patients\ndf[\"age_gap_raw\"]  = df.apply(compute_bio_age_gap, axis=1)\n\n# Calibrate: anchor healthy mean to 0 so gap is purely relative\ncalibration_offset = df.loc[df[\"stroke\"] == 0, \"age_gap_raw\"].mean()\ndf[\"age_gap\"]      = df[\"age_gap_raw\"] - calibration_offset\ndf[\"bio_age\"]      = df[\"age\"] + df[\"age_gap\"]\ndf[\"accelerated\"]  = (df[\"age_gap\"] > 0).astype(int)  # 1 if biologically older\n\n# Refresh group splits with computed columns\nhealthy = df[df[\"stroke\"] == 0].copy()\nstroke  = df[df[\"stroke\"] == 1].copy()\n\n# Add age groups for subgroup analysis\ndf[\"age_group\"] = pd.cut(df[\"age\"], bins=[17,40,55,65,120],\n                          labels=[\"18–40\", \"40–55\", \"55–65\", \"65+\"])\nhealthy = df[df[\"stroke\"] == 0].copy()\nstroke  = df[df[\"stroke\"] == 1].copy()\n\nprint(\"✅ Biological age computed for all patients\")\nprint(f\"\\n  Sample output (5 rows):\")\ndf[[\"age\",\"bio_age\",\"age_gap\",\"accelerated\",\"stroke\"]].head()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-01T23:07:56.954155Z","iopub.execute_input":"2026-03-01T23:07:56.954451Z","iopub.status.idle":"2026-03-01T23:07:59.246258Z","shell.execute_reply.started":"2026-03-01T23:07:56.954402Z","shell.execute_reply":"2026-03-01T23:07:59.245477Z"},"jupyter":{"source_hidden":true}},"outputs":[{"name":"stdout","text":"✅ Biological age computed for all patients\n\n  Sample output (5 rows):\n","output_type":"stream"},{"execution_count":6,"output_type":"execute_result","data":{"text/plain":"    age  bio_age  age_gap  accelerated  stroke\n0 67.00    74.30     7.30            1       1\n1 80.00    81.35     1.35            1       1\n2 49.00    51.90     2.90            1       1\n3 79.00    81.80     2.80            1       1\n4 81.00    81.27     0.27            1       1","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>age</th>\n      <th>bio_age</th>\n      <th>age_gap</th>\n      <th>accelerated</th>\n      <th>stroke</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>67.00</td>\n      <td>74.30</td>\n      <td>7.30</td>\n      <td>1</td>\n      <td>1</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>80.00</td>\n      <td>81.35</td>\n      <td>1.35</td>\n      <td>1</td>\n      <td>1</td>\n    </tr>\n    <tr>\n      <th>2</th>\n      <td>49.00</td>\n      <td>51.90</td>\n      <td>2.90</td>\n      <td>1</td>\n      <td>1</td>\n    </tr>\n    <tr>\n      <th>3</th>\n      <td>79.00</td>\n      <td>81.80</td>\n      <td>2.80</td>\n      <td>1</td>\n      <td>1</td>\n    </tr>\n    <tr>\n      <th>4</th>\n      <td>81.00</td>\n      <td>81.27</td>\n      <td>0.27</td>\n      <td>1</td>\n      <td>1</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}}],"execution_count":6},{"cell_type":"markdown","source":"## Statistical Testing & PRedictive Validation","metadata":{}},{"cell_type":"code","source":"# ─────────────────────────────────────────────────────────────────────\n# SECTION 7 ── STATISTICAL TESTING\n# ─────────────────────────────────────────────────────────────────────\ngap_h = healthy[\"age_gap\"]\ngap_s = stroke[\"age_gap\"]\n\n# Mann-Whitney U: non-parametric, works well with imbalanced groups\n# alternative=\"greater\" tests: stroke gap > no-stroke gap\nmw_stat, p_val = stats.mannwhitneyu(gap_s, gap_h, alternative=\"greater\")\n\n# Effect size\npooled_std = np.sqrt((gap_h.std()**2 + gap_s.std()**2) / 2)\ncohens_d   = (gap_s.mean() - gap_h.mean()) / pooled_std\n\n# Correlation between bio-age gap and stroke label\ncorr, p_corr = stats.pointbiserialr(df[\"stroke\"], df[\"age_gap\"])\n\nprint(\"=\" * 55)\nprint(\"   CORE RESULTS — AGE GAP COMPARISON\")\nprint(\"=\" * 55)\nprint(f\"\\n  {'Metric':<24} {'No Stroke':>12} {'Stroke':>10}\")\nprint(\"  \" + \"-\" * 48)\nprint(f\"  {'Mean Gap':24} {gap_h.mean():>+12.2f} {gap_s.mean():>+10.2f}  years\")\nprint(f\"  {'Median Gap':24} {gap_h.median():>+12.2f} {gap_s.median():>+10.2f}  years\")\nprint(f\"  {'Std Deviation':24} {gap_h.std():>12.2f} {gap_s.std():>10.2f}  years\")\nprint(f\"  {'% Biologically Older':24} {(gap_h>0).mean()*100:>11.1f}% {(gap_s>0).mean()*100:>9.1f}%\")\nprint(f\"  {'N (patients)':24} {len(gap_h):>12,} {len(gap_s):>10,}\")\n\nsig = \"  SIGNIFICANT\" if p_val < 0.05 else \"❌ Not significant\"\neffect_label = \"large\" if abs(cohens_d)>0.8 else \"medium\" if abs(cohens_d)>0.5 else \"small\"\n\nprint(f\"\"\"\n  ─── Statistical Tests ───────────────────────────────\n  Mann-Whitney U p-value : {p_val:.6f}  {sig}\n  Cohen's d              : {cohens_d:.3f}  ({effect_label} effect size)\n  Point-biserial r       : {corr:.3f}  (p={p_corr:.2e})\n\n     Interpretation:\n     p < 0.05 confirms the gap difference is NOT due to chance.\n     Cohen's d = 0.318 = small-but-real effect. Expected here\n     because we lack deep biomarkers (albumin, CRP, creatinine).\n     With richer lab data this effect would be larger.\n\"\"\")\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 8 ── PREDICTIVE VALIDATION\n# ─────────────────────────────────────────────────────────────────────\n# Does biological age predict stroke BETTER than chronological age?\n# We use 5-fold stratified cross-validation + Logistic Regression (LR).\n# Metric: ROC-AUC (1.0 = perfect, 0.5 = random guessing)\n\nprint(\"=\" * 55)\nprint(\"   PREDICTIVE VALIDATION  (5-Fold CV AUC)\")\nprint(\"=\" * 55)\n\nskf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\nlr  = LogisticRegression(max_iter=1000)\n\nresults = {}\nexperiments = {\n    \"Chronological Age only\": df[[\"age\"]],\n    \"Biological Age only\"   : df[[\"bio_age\"]],\n    \"Age Gap only\"          : df[[\"age_gap\"]],\n    \"Chrono Age + Age Gap\"  : df[[\"age\",\"age_gap\"]],\n}\nfor name, X in experiments.items():\n    auc = cross_val_score(lr, X, df[\"stroke\"], cv=skf, scoring=\"roc_auc\").mean()\n    results[name] = auc\n\nbaseline = results[\"Chronological Age only\"]\nprint(f\"\\n  {'Model':<28} {'AUC':>7}  {'vs Baseline':>12}\")\nprint(\"  \" + \"-\" * 52)\nfor name, auc in results.items():\n    delta = auc - baseline\n    marker = \"⭐\" if auc == max(results.values()) else \"  \"\n    print(f\"  {marker} {name:<26} {auc:.4f}  {delta:>+11.2%}\")\n\nprint(f\"\"\"\n     Interpretation:\n     Biological Age (0.8171) beats Chronological Age (0.8053).\n     The +1.2% AUC gain means bio-age captures risk that birthday\n     alone cannot. In clinical terms this could change treatment\n     decisions for borderline patients.\n\"\"\")\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 9 ── SUBGROUP ANALYSIS\n# ─────────────────────────────────────────────────────────────────────\nprint(\"=\" * 55)\nprint(\"🔍  SUBGROUP ANALYSIS  (Mean Bio-Age Gap)\")\nprint(\"=\" * 55)\n\nsubgroups = {\n    \"Hypertension\"   : \"hypertension\",\n    \"Heart Disease\"  : \"heart_disease\",\n    \"Smoking Status\" : \"smoking_status\",\n    \"Gender\"         : \"gender\",\n}\n\nfor label, col in subgroups.items():\n    tbl = (df.groupby([col, \"stroke\"])[\"age_gap\"]\n             .mean()\n             .unstack(fill_value=0)\n             .round(2))\n    tbl.columns = [\"No Stroke (gap)\", \"Stroke (gap)\"]\n    tbl[\"Difference\"] = (tbl[\"Stroke (gap)\"] - tbl[\"No Stroke (gap)\"]).round(2)\n    print(f\"\\n  ── By {label} {'─'*(35-len(label))}\")\n    print(tbl.to_string())\n\nprint(\"\"\"\n     Key takeaways:\n     • Hypertensive patients carry a +4.4yr gap regardless of stroke\n     • Heart disease + stroke = highest combined gap (+4.85yrs)\n     • Active smokers who had strokes show gap 3× higher than non-smokers\n     • Male stroke patients age +1.12yrs faster than female stroke patients\n\"\"\")\n\n# ─────────────────────────────────────────────────────────────────────\n# SECTION 10 ── VISUALISATIONS\n# ─────────────────────────────────────────────────────────────────────\nprint(\"=\" * 55)\nprint(\"    GENERATING CHARTS...\")\nprint(\"=\" * 55)\n\n# ── Colour scheme ─────────────────────────────────────────────────────\nSTROKE_COLOR  = \"#FF4D6D\"   # red\nHEALTHY_COLOR = \"#00C9A7\"   # teal\nGOLD          = \"#FFD166\"   # yellow accent\nMUTED         = \"#5A7290\"   # grey\nBG            = \"#080E1A\"