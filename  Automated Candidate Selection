e:GPU:0', device_type='GPU')]\nCUDA (PyTorch): True | Device: Tesla P100-PCIE-16GB\n","output_type":"stream"}],"execution_count":4},{"cell_type":"markdown","source":"## Data Loading ","metadata":{}},{"cell_type":"code","source":"# ─── Paths ───────────────────────────────────────────────────────────────────\nclinical_path   = '/kaggle/input/alzheimers-disease-dataset/alzheimers_disease_data.csv'\noasis_path      = '/kaggle/input/mri-and-alzheimers/oasis_cross-sectional.csv'\nimage_directory = '/kaggle/input/alzheimer-mri-4-classes-dataset/Alzheimer_MRI_4_classes_dataset'\n\n# ─── Clinical Data ───────────────────────────────────────────────────────────\nif not os.path.exists(clinical_path):\n    raise FileNotFoundError(f\"Clinical dataset not found at: {clinical_path}\")\ndf_clinical = pd.read_csv(clinical_path)\ndf_clinical['Stage_Index'] = df_clinical['Diagnosis']  # 0=Healthy, 1=Impaired\n\n# ─── OASIS Structural / Biological Data ──────────────────────────────────────\nif not os.path.exists(oasis_path):\n    raise FileNotFoundError(f\"OASIS dataset not found at: {oasis_path}\")\ndf_oasis = pd.read_csv(oasis_path)\ndf_oasis = df_oasis.dropna(subset=['nWBV', 'CDR'])\ndf_oasis['Stage_Index'] = df_oasis['CDR'].apply(lambda x: 1 if x > 0 else 0)\n\n# Pre-compute group-level nWBV means (used in MedGemma prompt as a grounded biomarker)\n# FIX: nWBV is now actually used rather than loaded and discarded\nnwbv_by_stage = df_oasis.groupby('Stage_Index')['nWBV'].mean().to_dict()\nprint(f\"Group mean nWBV — Healthy: {nwbv_by_stage.get(0, np.nan):.4f} | Impaired: {nwbv_by_stage.get(1, np.nan):.4f}\")\n\n# ─── Train / Val Split on Clinical BEFORE Scaling ────────────────────────────\n# FIX: fit_transform was previously applied to ALL rows, leaking val distribution into scaler\nclinical_features_list = ['Age', 'BMI', 'MMSE', 'FunctionalAssessment']\ndf_train_clin, df_val_clin = train_test_split(\n    df_clinical, test_size=0.2, random_state=42, stratify=df_clinical['Stage_Index']\n)\ndf_train_clin = df_train_clin.copy()\ndf_val_clin   = df_val_clin.copy()\n\nscaler = StandardScaler()\ndf_train_clin[clinical_features_list] = scaler.fit_transform(df_train_clin[clinical_features_list])\ndf_val_clin[clinical_features_list]   = scaler.transform(df_val_clin[clinical_features_list])  # transform only\n\n# ─── Patient Profile Banks ───────────────────────────────────────────────────\n# Stage-keyed lookup used by the multimodal generator to sample matching profiles\ntrain_clinical_bank = {\n    0: df_train_clin[df_train_clin['Stage_Index'] == 0],\n    1: df_train_clin[df_train_clin['Stage_Index'] == 1],\n}\nval_clinical_bank = {\n    0: df_val_clin[df_val_clin['Stage_Index'] == 0],\n    1: df_val_clin[df_val_clin['Stage_Index'] == 1],\n}\n\nprint(f\"\\n--- Data Harmonization Summary ---\")\nprint(f\"Clinical rows: {len(df_clinical)} → Train: {len(df_train_clin)} | Val: {len(df_val_clin)}\")\nprint(f\"Train bank — Stage 0 (Healthy): {len(train_clinical_bank[0])} | Stage 1 (Impaired): {len(train_clinical_bank[1])}\")\nprint(f\"OASIS structural rows (after dropna): {len(df_oasis)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T01:54:55.335560Z","iopub.execute_input":"2026-02-23T01:54:55.336201Z","iopub.status.idle":"2026-02-23T01:54:55.428232Z","shell.execute_reply.started":"2026-02-23T01:54:55.336174Z","shell.execute_reply":"2026-02-23T01:54:55.427524Z"}},"outputs":[{"name":"stdout","text":"Group mean nWBV — Healthy: 0.7692 | Impaired: 0.7220\n\n--- Data Harmonization Summary ---\nClinical rows: 2149 → Train: 1719 | Val: 430\nTrain bank — Stage 0 (Healthy): 1111 | Stage 1 (Impaired): 608\nOASIS structural rows (after dropna): 235\n","output_type":"stream"}],"execution_count":5},{"cell_type":"markdown","source":"## Image Generators & Class Index Alignment","metadata":{}},{"cell_type":"code","source":"# ─── Image Data Generators ───────────────────────────────────────────────────\ntrain_datagen = ImageDataGenerator(\n    rescale=1./255,\n    validation_split=0.2,\n    rotation_range=10,\n    width_shift_range=0.05,\n    height_shift_range=0.05,\n    horizontal_flip=True,\n)\nval_datagen = ImageDataGenerator(rescale=1./255, validation_split=0.2)\n\ntrain_generator = train_datagen.flow_from_directory(\n    image_directory, target_size=(128, 128), batch_size=32,\n    class_mode='categorical', subset='training', shuffle=True, seed=42\n)\n# FIX: Validation generator was missing entirely in original\nval_generator = val_datagen.flow_from_directory(\n    image_directory, target_size=(128, 128), batch_size=32,\n    class_mode='categorical', subset='validation', shuffle=False, seed=42\n)\n\n# ─── Class Index Alignment ───────────────────────────────────────────────────\n\nCLASS_INDICES = train_generator.class_indices   # e.g. {'MildDemented': 0, ...}\nIDX_TO_LABEL  = {v: k for k, v in CLASS_INDICES.items()}\nNUM_CLASSES   = len(CLASS_INDICES)\nCLASSES       = [IDX_TO_LABEL[i] for i in range(NUM_CLASSES)]\n\n# Verified integer indices for use in masks below\nMILD_IDX      = CLASS_INDICES['MildDemented']\nMODERATE_IDX  = CLASS_INDICES['ModerateDemented']\nNON_DEM_IDX   = CLASS_INDICES['NonDemented']\nVERY_MILD_IDX = CLASS_INDICES['VeryMildDemented']\n\ndef class_idx_to_stage(class_idx: int) -> int:\n    \"\"\"Map MRI class index → clinical stage (0=Healthy, 1=Impaired).\"\"\"\n    return 0 if class_idx == NON_DEM_IDX else 1\n\nprint(f\"Verified Class Indices: {CLASS_INDICES}\")\nprint(f\"Classes in order:       {CLASSES}\")\nprint(f\"Train images: {train_generator.samples} | Val images: {val_generator.samples}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T01:54:55.430190Z","iopub.execute_input":"2026-02-23T01:54:55.430462Z","iopub.status.idle":"2026-02-23T01:55:00.270975Z","shell.execute_reply.started":"2026-02-23T01:54:55.430437Z","shell.execute_reply":"2026-02-23T01:55:00.270374Z"}},"outputs":[{"name":"stdout","text":"Found 5121 images belonging to 4 classes.\nFound 1279 images belonging to 4 classes.\nVerified Class Indices: {'MildDemented': 0, 'ModerateDemented': 1, 'NonDemented': 2, 'VeryMildDemented': 3}\nClasses in order:       ['MildDemented', 'ModerateDemented', 'NonDemented', 'VeryMildDemented']\nTrain images: 5121 | Val images: 1279\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"## Multimodal Data Generator","metadata":{}},{"cell_type":"code","source":"def multimodal_generator(image_gen, clinical_bank):\n    \"\"\"\n    Bridges the dataset size mismatch (5121 clinical rows vs MRI folder count)\n    by stage-matched sampling: for each image in a batch, a random clinical\n    profile of the same impairment stage is drawn.\n\n    Yields: ((img_batch, clin_batch), label_batch)\n    \"\"\"\n    while True:\n        img_batch, label_batch = next(image_gen)\n        batch_size = img_batch.shape[0]\n        clin_batch = np.zeros((batch_size, len(clinical_features_list)), dtype=np.float32)\n\n        for i in range(batch_size):\n            class_idx = int(np.argmax(label_batch[i]))\n            stage     = class_idx_to_stage(class_idx)\n            bank      = clinical_bank[stage]\n            # Fallback if a stage has no samples in this split (edge case)\n            if len(bank) == 0:\n                bank = clinical_bank[1 - stage]\n            clin_batch[i] = bank.sample(1)[clinical_features_list].values\n\n        yield (img_batch, clin_batch), label_batch\n\n\n# ─── Smoke-test the generator ─────────────────────────────────────────────────\ntrain_multi_gen = multimodal_generator(train_generator, train_clinical_bank)\nval_multi_gen   = multimodal_generator(val_generator,   val_clinical_bank)\n\n(imgs, clins), lbls = next(train_multi_gen)\nprint(\"--- Multimodal Generator Verified ---\")\nprint(f\"MRI batch shape:      {imgs.shape}    (Biological signal)\")\nprint(f\"Clinical batch shape: {clins.shape}        (Contextual signal)\")\nprint(f\"Labels shape:         {lbls.shape}\")\nprint(f\"Sample clinical row:  {dict(zip(clinical_features_list, clins[0].round(3)))}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T01:55:00.271890Z","iopub.execute_input":"2026-02-23T01:55:00.272287Z","iopub.status.idle":"2026-02-23T01:55:00.622465Z","shell.execute_reply.started":"2026-02-23T01:55:00.272253Z","shell.execute_reply":"2026-02-23T01:55:00.621660Z"}},"outputs":[{"name":"stdout","text":"--- Multimodal Generator Verified ---\nMRI batch shape:      (32, 128, 128, 3)    (Biological signal)\nClinical batch shape: (32, 4)        (Contextual signal)\nLabels shape:         (32, 4)\nSample clinical row:  {'Age': np.float32(-0.655), 'BMI': np.float32(0.467), 'MMSE': np.float32(-0.774), 'FunctionalAssessment': np.float32(-0.905)}\n","output_type":"stream"}],"execution_count":7},{"cell_type":"markdown","source":"## Two-Tower Multimodal Model\n**Tower 1 (Biological):** EfficientNetB0 pretrained on ImageNet — far deeper than the original single Conv2D layer, with the last 20 layers unfrozen for fine-tuning on MRI data.  \n**Tower 2 (Contextual):** Dense sub-network for low-dimensional cognitive/functional markers.  \n**Fusion:** Concatenated embedding space — the latent vector from which Goldilocks distances are computed.","metadata":{}},{"cell_type":"code","source":"def build_multimodal_model(num_classes: int) -> models.Model:\n    # ── Tower 1: Biological Signal (MRI) ─────────────────────────────────────\n    # GAP with EfficientNetB0 pretrained backbone\n    image_input = layers.Input(shape=(128, 128, 3), name=\"mri_input\")\n    backbone    = EfficientNetB0(\n        include_top=False,\n        weights='imagenet',\n        input_tensor=image_input\n    )\n    # Freeze early feature-extraction layers; fine-tune the last 20\n    for layer in backbone.layers[:-20]:\n        layer.trainable = False\n    for layer in backbone.layers[-20:]:\n        layer.trainable = True\n\n    x = backbone.output\n    x = layers.GlobalAveragePooling2D()(x)\n    x = layers.Dense(128, activation='relu')(x)\n    x = layers.Dropout(0.3)(x)\n\n    # ── Tower 2: Contextual Signal (Clinical) ─────────────────────────────────\n    clin_input = layers.Input(shape=(len(clinical_features_list),), name=\"clinical_input\")\n    y = layers.Dense(32, activation='relu')(clin_input)\n    y = layers.BatchNormalization()(y)\n    y = layers.Dense(32, activation='relu')(y)\n    y = layers.Dropout(0.2)(y)\n\n    # ── Fusion: Stage-by-Subtype Embedding Space ───────────────────────────────\n    merged    = layers.Concatenate()([x, y])\n    embedding = layers.Dense(128, activation='relu', name=\"embedding_space\")(merged)\n    embedding = layers.Dropout(0.3)(embedding)\n\n    # ── Output ────────────────────────────────────────────────────────────────\n    output = layers.Dense(num_classes, activation='softmax', name=\"diagnosis_output\")(embedding)\n\n    model = models.Model(inputs=[image_input, clin_input], outputs=output)\n    model.compile(\n        optimizer=tf.keras.optimizers.Adam(learning_rate=1e-4),\n        loss='categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    return model\n\n\nmodel = build_multimodal_model(NUM_CLASSES)\nmodel.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T01:55:00.623496Z","iopub.execute_input":"2026-02-23T01:55:00.624041Z","iopub.status.idle":"2026-02-23T01:55:05.924146Z","shell.execute_reply.started":"2026-02-23T01:55:00.624009Z","shell.execute_reply":"2026-02-23T01:55:05.923511Z"}},"outputs":[{"name":"stderr","text":"I0000 00:00:1771811700.795975      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 15511 MB memory:  -> device: 0, name: Tesla P100-PCIE-16GB, pci bus id: 0000:00:04.0, compute capability: 6.0\n","output_type":"stream"},{"name":"stdout","text":"Downloading data from https://storage.googleapis.com/keras-applications/efficientnetb0_notop.h5\n\u001b[1m16705208/16705208\u001b[0m \u001b[32m━━━━━━━━━━━━━━━