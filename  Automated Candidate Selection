luster: \" + f\"{prox:.4f}\",\n        \"  (Top \" + str(prox_pct) + \"% closest to Moderate Dementia despite current diagnosis of \" + str(label) + \")\",\n        \"\",\n        \"Based on the MRI scan above and the quantitative evidence, explain in 3-4 sentences:\",\n        \"1. What the structural and cognitive discrepancy suggests about disease trajectory.\",\n        \"2. Why this patient is an ideal imminent progressor for a disease-modifying drug trial.\",\n    ]\n    clinical_text = \"\\n\".join(lines)\n\n    # ── Correct Gemma3 / MedGemma message format ─────────────────────────────\n    messages = [\n        {\n            \"role\": \"system\",\n            \"content\": [{\n                \"type\": \"text\",\n                \"text\": (\n                    \"You are a clinical trial screening specialist with expertise in \"\n                    \"neurodegenerative disease. Analyse the provided MRI and patient \"\n                    \"metrics to produce concise, evidence-grounded clinical reasoning.\"\n                )\n            }]\n        },\n        {\n            \"role\": \"user\",\n            \"content\": [\n                {\"type\": \"image\", \"image\": mri_pil},\n                {\"type\": \"text\",  \"text\": clinical_text},\n            ]\n        }\n    ]\n\n    # apply_chat_template handles <image> sentinel token placement\n    inputs = processor.apply_chat_template(\n        messages,\n        add_generation_prompt=True,\n        tokenize=True,\n        return_dict=True,\n        return_tensors=\"pt\",\n    ).to(\"cuda\")\n\n    with torch.no_grad():\n        output_ids = reasoning_model.generate(\n            **inputs,\n            max_new_tokens=220,\n            do_sample=False,\n            temperature=None,\n            top_p=None,\n        )\n\n    # Decode only newly generated tokens — avoids prompt echo\n    input_len = inputs[\"input_ids\"].shape[-1]\n    decoded   = processor.decode(output_ids[0][input_len:], skip_special_tokens=True).strip()\n    return decoded\n\n\n# ── Execute for Top 3 Candidates ─────────────────────────────────────────────\nprint(\"\\n=== MEDGEMMA CLINICAL JUSTIFICATIONS ===\")\nprint(\"(Grounded in computed proximity scores and nWBV)\\n\")\n\nfor rank_i in range(min(3, len(df_goldilocks))):\n    row = df_goldilocks.iloc[rank_i]\n    print(\"─\" * 60)\n    print(\n        f\"[Candidate #{rank_i + 1}]  Label: {row['Clinical Label']}  \"\n        f\"| Proximity: {row['Proximity_Score']}  \"\n        f\"| MMSE: {row['MMSE']}  \"\n        f\"| nWBV: {row['Group_nWBV']}\"\n    )\n    print(\"─\" * 60)\n    reasoning = get_medgemma_reasoning(rank_i, df_goldilocks, all_imgs[final_indices])\n    print(reasoning)\n    print()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T02:38:41.620556Z","iopub.execute_input":"2026-02-23T02:38:41.620902Z","iopub.status.idle":"2026-02-23T02:40:00.538213Z","shell.execute_reply.started":"2026-02-23T02:38:41.620872Z","shell.execute_reply":"2026-02-23T02:40:00.537333Z"}},"outputs":[{"name":"stderr","text":"Setting `pad_token_id` to `eos_token_id`:1 for open-end generation.\n","output_type":"stream"},{"name":"stdout","text":"\n=== MEDGEMMA CLINICAL JUSTIFICATIONS ===\n(Grounded in computed proximity scores and nWBV)\n\n────────────────────────────────────────────────────────────\n[Candidate #1]  Label: VeryMildDemented  | Proximity: 0.9276  | MMSE: 12.6899995803833  | nWBV: 0.722\n────────────────────────────────────────────────────────────\n","output_type":"stream"},{"name":"stderr","text":"Setting `pad_token_id` to `eos_token_id`:1 for open-end generation.\n","output_type":"stream"},{"name":"stdout","text":"\n\n────────────────────────────────────────────────────────────\n[Candidate #2]  Label: VeryMildDemented  | Proximity: 0.956  | MMSE: 12.6899995803833  | nWBV: 0.722\n────────────────────────────────────────────────────────────\n","output_type":"stream"},{"name":"stderr","text":"Setting `pad_token_id` to `e