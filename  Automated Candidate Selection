s.busy":"2026-02-23T02:06:38.835268Z","iopub.execute_input":"2026-02-23T02:06:38.835559Z","iopub.status.idle":"2026-02-23T02:06:39.491563Z","shell.execute_reply.started":"2026-02-23T02:06:38.835532Z","shell.execute_reply":"2026-02-23T02:06:39.490803Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nBest Val Accuracy: 0.6637 at epoch 6\n","output_type":"stream"}],"execution_count":11},{"cell_type":"markdown","source":"## Embedding Space Extraction & t-SNE Visualization","metadata":{}},{"cell_type":"code","source":"# Extract the trained embedding layer (now meaningful — model is actually trained)\nembedding_model = models.Model(\n    inputs=model.input,\n    outputs=model.get_layer('embedding_space').output\n)\n\n# Aggregate multiple validation batches for a richer t-SNE map\nN_BATCHES = 8\nall_imgs, all_clins, all_labels = [], [], []\ntemp_gen = multimodal_generator(val_generator, val_clinical_bank)\n\nfor _ in range(N_BATCHES):\n    (bi, bc), bl = next(temp_gen)\n    all_imgs.append(bi); all_clins.append(bc); all_labels.append(bl)\n\nall_imgs   = np.concatenate(all_imgs,   axis=0)\nall_clins  = np.concatenate(all_clins,  axis=0)\nall_labels = np.concatenate(all_labels, axis=0)\nall_label_indices = np.argmax(all_labels, axis=1)\n\nprint(f\"Generating embeddings for {len(all_imgs)} samples...\")\nembeddings = embedding_model.predict([all_imgs, all_clins], verbose=0)\nprint(f\"Embedding shape: {embeddings.shape}\")\n\n# t-SNE\ntsne        = TSNE(n_components=2, random_state=42, perplexity=30)\ntsne_coords = tsne.fit_transform(embeddings)\n\nplt.figure(figsize=(11, 8))\nscatter = plt.scatter(\n    tsne_coords[:, 0], tsne_coords[:, 1],\n    c=all_label_indices, cmap='viridis', alpha=0.75, s=40, edgecolors='k', linewidths=0.3\n)\ncbar = plt.colorbar(scatter)\ncbar.set_ticks(range(NUM_CLASSES))\ncbar.set_ticklabels(CLASSES)\nplt.title(\"Prognostic Embedding Space — Multimodal t-SNE Map\", fontsize=14)\nplt.xlabel(\"t-SNE Dimension 1\"); plt.ylabel(\"t-SNE Dimension 2\")\nplt.tight_layout()\nplt.savefig('/kaggle/working/tsne_embedding_space.png', dpi=150)\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T02:06:44.767089Z","iopub.execute_input":"2026-02-23T02:06:44.767763Z","iopub.status.idle":"2026-02-23T02:06:52.819409Z","shell.execute_reply.started":"2026-02-23T02:06:44.767733Z","shell.execute_reply":"2026-02-23T02:06:52.818717Z"}},"outputs":[{"name":"stdout","text":"Generating embeddings for 256 samples...\nEmbedding shape: (256, 128)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1100x800 with 2 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":12},{"cell_type":"markdown","source":"## Identifying Goldilocks Candidates\n\nA patient is a **Goldilocks candidate** when their multimodal embedding — their unique combination of brain volume signal and cognitive scores — places them closest to the Moderate Dementia cluster despite a current Mild or VeryMild diagnosis. These patients are imminent progressors: their brain is ahead of their clinical label.","metadata":{}},{"cell_type":"code","source":"# ── Anchor: Moderate Dementia centroid in embedding space ─────────────────────\n\nmod_mask = all_label_indices == MODERATE_IDX\nif not np.any(mod_mask):\n    print(\"Warning: No Moderate Dementia samples in pooled batches. Widening pool...\")\n    temp_gen2 = multimodal_generator(val_generator, val_clinical_bank)\n    extra_imgs, extra_clins, extra_labels = [], [], []\n    for _ in range(4):\n        (bi, bc), bl = next(temp_gen2)\n        extra_imgs.append(bi); extra_clins.append(bc); extra_labels.append(bl)\n    extra_embeddings = embedding_model.predict(\n        [np.concatenate(extra_imgs), np.concatenate(extra_clins)], verbose=0\n    )\n    extra_label_idx = np.argmax(np.concatenate(extra_labels), axis=1)\n    mod_mask_ext    = extra_label_idx == MODERATE_IDX\n    mod_centroid    = extra_embeddings[mod_mask_ext].mean(axis=0) if np.any(mod_mask_ext) else embeddings.mean(axis=0)\nelse:\n    mod_centroid = embeddings[mod_mask].mean(axis=0)\n\nprint(f\"Moderate Dementia samples available for centroid: {mod_mask.sum()}\")\n\n# ── Candidates: Mild and VeryMild patients (potential imminent progressors) ────\n\ncandidate_mask     = np.isin(all_label_indices, [MILD_IDX, VERY_MILD_IDX])\ncandidate_indices  = np.where(candidate_mask)[0]\ncandidate_embeddings = embeddings[candidate_mask]\n\nprint(f\"Candidate pool size (Mild + VeryMild): {len(candidate_indices)}\")\n\n# ── Rank by distance to Moderate centroid ─────────────────────────────────────\ndistances      = cdist(candidate_embeddings, [mod_centroid], metric='euclidean').flatten()\ntop_k          = min(10, len(distances))\ngoldilocks_idx = np.argsort(distances)[:top_k]\nfinal_indices  = candidate_indices[goldilocks_idx]\n\n# ── Reconstruct real-unit clinical profiles ────────────────────────────────────\n\nreal_values = scaler.inverse_transform(all_clins[final_indices])\n\n# Build results table — now includes nWBV and Proximity Score as grounded metrics\nresults = []\nfor rank_i, idx in enumerate(final_indices):\n    label_idx  = all_label_indices[idx]\n    stage      = class_idx_to_stage(label_idx)\n    label_name = IDX_TO_LABEL[label_idx]\n    nwbv       = nwbv_by_stage.get(stage, np.nan)          # FIX: nWBV now used\n    prox_score = round(float(distances[goldilocks_idx[rank_i]]), 4)\n    row        = [label_name, prox_score, round(nwbv, 4)] + \\\n                 [round(v, 2) for v in real_values[rank_i]]\n    results.append(row)\n\ndf_goldilocks = pd.DataFrame(\n    results,\n    columns=['Clinical Label', 'Proximity_Score', 'Group_nWBV'] + clinical_features_list\n)\ndf_goldilocks.index.name = 'Rank'\n\nprint(\"\\n--- GOLDILOCKS CANDIDATE PROFILES ---\")\nprint(\"(Proximity_Score: distance to Moderate centroid — lower = closer to progression)\")\ndisplay(df_goldilocks)\n\n# ── MRI Slice Visualisation ────────────────────────────────────────────────────\nfig, axes = plt.subplots(2, 5, figsize=(22, 9))\nfig.suptitle(\"Biological Signals of Goldilocks Candidates (MRI Slices)\", fontsize=16)\n\nfor i, idx in enumerate(final_indices):\n    ax = axes[i // 5][i % 5]\n    ax.imshow(all_imgs[idx][:, :, 0], cmap='bone')\n    row = df_goldilocks.iloc[i]\n    ax.set_title(\n        f\"Rank {i+1}\\n{row['Clinical Label']}\\n\"\n        f\"Proximity: {row['Proximity_Score']:.3f}\\n\"\n        f\"MMSE: {row['MMSE']:.1f}\",\n        fontsize=8\n    )\n    ax.axis('off')\n\nplt.tight_layout()\nplt.savefig('/kaggle/working/goldilocks_candidates.png', dpi=150)\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-23T02:07:00.300294Z","iopub.execute_input":"2026-02-23T02:07:00.300988Z","iopub.status.idle":"2026-02-23T02:07:08.984263Z","shell.execute_reply.started":"2026-02-23T02:07:00.300952Z","shell.execute_reply":"2026-02-23T02:07:08.983286Z"}},"outputs":[{"name":"stdout","text":"Warning: No Moderate Dementia samples in pooled batches. Widening pool...\nModerate Dementia samples available for centroid: 0\nCandidate pool size (Mild + VeryMild): 256\n\n--- GOLDILOCKS CANDIDATE PROFILES ---\n(Proximity_Score: distance to Moderate centroid — lower = closer to progression)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"        Clinical Label  Proximity_Score  Group_nWBV   Age        BMI   MMSE  \\\nRank                                                                          \n0     VeryMildDemented           0.9276       0.722  70.0  25.480000  12.69   \n1     VeryMildDemented           0.9560       0.722  70.0  25.480000  12.69   \n2     VeryMildDemented           1.0165       0.722  73.0  20.049999  12.60   \n3     VeryMildDemented           1.0216       0.722  66.0  21.350000   4.06   \n4     VeryMildDemented           1.0240       0.722  66.0  21.350000   4.06   \n5   